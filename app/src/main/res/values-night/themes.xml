<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Dynamic attributes for dark mode -->
        <item name="bgPrimary">@color/bg_primary_dark</item>
        <item name="bgSecondary">@color/bg_secondary_dark</item>
        <item name="textPrimary">@color/text_primary_dark</item>
        <item name="textSecondary">@color/text_secondary_dark</item>
        
        <!-- Material theme -->
        <item name="colorPrimary">@color/apple_blue</item>
        <item name="colorPrimaryVariant">@color/apple_blue</item>
        <item name="colorOnPrimary">@color/text_primary_dark</item>
        <item name="android:windowBackground">@color/bg_primary_dark</item>
        <item name="android:statusBarColor">@color/bg_secondary_dark</item>
    </style>
</resources>
