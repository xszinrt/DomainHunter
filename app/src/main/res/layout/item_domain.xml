<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/bg_secondary"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    android:layout_marginBottom="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDomainName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/neon_green"
                android:textSize="13sp"
                android:textStyle="bold"
                 />

            <TextView
                android:id="@+id/tvExpiringSoon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textColor="@color/neon_yellow"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <TextView
                android:id="@+id/tvRegDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                 />

            <TextView
                android:id="@+id/tvExpDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                 />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFailed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❌"
            android:textColor="@color/neon_red"
            android:textSize="11sp"
            android:visibility="gone"
            android:paddingTop="2dp"
             />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="6dp"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnOpen"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_view"
                android:background="@drawable/neon_circle_small"
                android:tint="@color/neon_green"
                android:padding="6dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnCopy"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_save"
                android:background="@drawable/neon_circle_small"
                android:tint="@color/neon_blue"
                android:padding="6dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnGoogle"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:src="@android:drawable/ic_menu_search"
                android:background="@drawable/neon_circle_small"
                android:tint="@color/neon_yellow"
                android:padding="6dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
